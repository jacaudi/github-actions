{
  "plugins": {
    "commit-analyzer": {
      "name": "default@^1.0.0"
    },
    "changelog-generator": {
      "name": "default@^1.0.0",
      "options": {
        "emojis": "false",
        "format_commit_template": "* {{with .Scope -}} **{{.}}:** {{end}} {{- .Message}} ([{{trimSHA .SHA}}](https://github.com/jacaudi/github-actions/commit/{{.SHA}}))"
      }
    },
    "provider": {
      "name": "github"
    }
  }
}
